# Import libraries
# Google Colab has all of these pre-installed. Nothing to pip install.

import requests   # for making HTTP calls to the PubChem API
import pandas as pd  # for organizing data into a table
import time       # for adding polite pauses between API calls

print("Libraries ready ✓")

# Define your list of EGFR inhibitors
#
# These are the compounds from your NSCLC chapter, organized
# by generation. You can add any drug name — PubChem recognizes
# brand names, generic names, and synonyms.

DRUGS = [
    "gefitinib",      # Gen 1 — first-ever approved EGFR TKI
    "erlotinib",      # Gen 1 — also approved in pancreatic cancer
    "afatinib",       # Gen 2 — irreversible pan-HER inhibitor
    "dacomitinib",    # Gen 2 — pan-HER TKI, fewer resistance issues
    "osimertinib",    # Gen 3 — designed for T790M resistance mutation
    "rociletinib",    # Gen 3 — failed Phase III (good for comparison)
    "lapatinib",      # Dual EGFR/HER2 — also used in breast cancer
    "neratinib",      # Irreversible EGFR/HER2/HER4 inhibitor
    "vandetanib",     # EGFR + VEGFR2 + RET — thyroid cancer use
    "mobocertinib",   # Designed for EGFR exon 20 insertions
]

print(f"Drug list ready: {len(DRUGS)} compounds")

# Define helper functions
#
# Two functions:
#   get_cid()        → converts a drug name to a PubChem ID number
#   get_properties() → fetches molecular data using that ID

def get_cid(drug_name):
    """
    Looks up a drug name on PubChem and returns its Compound ID (CID).
    The CID is PubChem's unique number for each molecule — like a
    fingerprint identifier. We need it to fetch properties.

    Returns: int (CID) or None if the drug wasn't found
    """
    url = (
        "https://pubchem.ncbi.nlm.nih.gov/rest/pug"
        f"/compound/name/{drug_name}/cids/JSON"
    )
    try:
        response = requests.get(url, timeout=10)
        if response.status_code == 200:
            cid = response.json()["IdentifierList"]["CID"][0]
            return cid
        else:
            print(f"  WARNING: No CID found for '{drug_name}'")
            return None
    except Exception as e:
        print(f"  ERROR looking up '{drug_name}': {e}")
        return None


def get_properties(cid, drug_name):
    """
    Given a CID, fetches molecular properties from PubChem.
    Returns a dictionary with all the data.

    Properties fetched:
      - MolecularFormula: e.g. C22H24ClFN4O3
      - MolecularWeight:  in g/mol
      - IsomericSMILES:   string encoding the full 3D structure
      - XLogP:            lipophilicity score (higher = more fat-soluble)
      - HBondDonorCount:  number of hydrogen bond donors (NH, OH groups)
      - HBondAcceptorCount: number of H-bond acceptors (N, O atoms)
      - RotatableBondCount: flexibility of the molecule
      - TPSA:             topological polar surface area (affects absorption)
    """
    properties_to_fetch = ",".join([
        "MolecularFormula",
        "MolecularWeight",
        "IsomericSMILES",
        "XLogP",
        "HBondDonorCount",
        "HBondAcceptorCount",
        "RotatableBondCount",
        "TPSA",
    ])
    url = (
        "https://pubchem.ncbi.nlm.nih.gov/rest/pug"
        f"/compound/cid/{cid}/property/{properties_to_fetch}/JSON"
    )
    try:
        response = requests.get(url, timeout=10)
        if response.status_code == 200:
            data = response.json()["PropertyTable"]["Properties"][0]
            data["Drug_Name"] = drug_name.capitalize()
            data["PubChem_CID"] = cid
            return data
        else:
            print(f"  WARNING: No properties returned for CID {cid}")
            return None
    except Exception as e:
        print(f"  ERROR fetching properties for CID {cid}: {e}")
        return None


print("Functions defined ✓")

# Main scraping loop
#
# For each drug name:
#   1. Call get_cid() to find its PubChem ID
#   2. Call get_properties() to get its molecular data
#   3. Store the result
#   4. Wait 0.5 seconds (PubChem asks for this — be polite)

results = []

print("Starting API calls...\n")

for drug in DRUGS:
    print(f"Fetching: {drug}")

    # Step 1: Get PubChem ID
    cid = get_cid(drug)
    if cid is None:
        print(f"  Skipping {drug} — could not find CID\n")
        continue
    print(f"  CID: {cid}")

    # Step 2: Get molecular properties
    props = get_properties(cid, drug)
    if props is not None:
        results.append(props)
        mw    = props.get("MolecularWeight", "N/A")
        xlogp = props.get("XLogP", "N/A")
        print(f"  MW: {mw} g/mol | XLogP: {xlogp} | SMILES: obtained ✓")

    # Step 3: Polite pause between requests
    time.sleep(0.5)
    print()

print("─" * 40)
print(f"Done! Retrieved data for {len(results)}/{len(DRUGS)} compounds.")

# Build a DataFrame and add Lipinski's Rule of Five check
#
# Lipinski's Rule of Five (Ro5) defines "drug-likeness".
# A compound is considered drug-like if it breaks AT MOST ONE rule:
#   Rule 1: Molecular Weight  ≤ 500 g/mol
#   Rule 2: XLogP             ≤ 5  (not too greasy/fat-soluble)
#   Rule 3: H-Bond Donors     ≤ 5
#   Rule 4: H-Bond Acceptors  ≤ 10
#
# This predicts oral bioavailability — essential for a drug taken as a pill.
# Most EGFR TKIs are designed to be orally bioavailable, so most should pass.


def check_lipinski(row):
    """
    Counts how many Lipinski rules a compound violates.
    Returns 'pass' (0–1 violations) or 'fail (N violations)'.
    """
    violations = 0
    try:
        if float(row.get("MolecularWeight",    0)) > 500: violations += 1
        if float(row.get("XLogP",              0)) > 5:   violations += 1
        if   int(row.get("HBondDonorCount",    0)) > 5:   violations += 1
        if   int(row.get("HBondAcceptorCount", 0)) > 10:  violations += 1
    except (ValueError, TypeError):
        return "unknown"

    if violations <= 1:
        return "pass"
    else:
        return f"fail ({violations} violations)"


# Build the DataFrame from our list of result dicts
df = pd.DataFrame(results)

# Add the Lipinski column
df["Lipinski_Ro5"] = df.apply(check_lipinski, axis=1)

# Rename columns to be more readable in the final CSV
df.rename(columns={
    "Drug_Name":          "Name",
    "PubChem_CID":        "CID",
    "MolecularFormula":   "Formula",
    "MolecularWeight":    "MW_g_mol",
    "IsomericSMILES":     "SMILES",
    "HBondDonorCount":    "HB_Donors",
    "HBondAcceptorCount": "HB_Acceptors",
    "RotatableBondCount": "Rotatable_Bonds",
    "TPSA":               "TPSA_A2",
}, inplace=True)

# Final column order (SMILES last — it's a long string)
col_order = [
    "Name", "CID", "Formula", "MW_g_mol",
    "XLogP", "HB_Donors", "HB_Acceptors",
    "Rotatable_Bonds", "TPSA_A2", "Lipinski_Ro5", "SMILES"
]
col_order = [c for c in col_order if c in df.columns]
df = df[col_order]

# Preview the key columns
print("\nQUICK PREVIEW:")
print(df[["Name", "MW_g_mol", "XLogP", "Lipinski_Ro5"]].to_string(index=False))
print(f"\nTotal rows: {len(df)}")

